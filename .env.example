# GeneratorSettings
VMF_GENERATOR_TARGET_UE_NAME=UE
VMF_GENERATOR_VIA_HOST=proxy.example.com
VMF_GENERATOR_VIA_PORT=5060
VMF_GENERATOR_TRANSPORT=UDP
VMF_GENERATOR_USER_AGENT=volte-mutation-fuzzer/0.1.0

# From header defaults
VMF_GENERATOR_FROM_DISPLAY_NAME=Remote
VMF_GENERATOR_FROM_USER=remote
VMF_GENERATOR_FROM_HOST=example.com
VMF_GENERATOR_FROM_PORT=

# To header defaults
VMF_GENERATOR_TO_DISPLAY_NAME=UE
VMF_GENERATOR_TO_USER=ue
VMF_GENERATOR_TO_HOST=example.com
VMF_GENERATOR_TO_PORT=

# Request-URI defaults
VMF_GENERATOR_REQUEST_URI_USER=ue
VMF_GENERATOR_REQUEST_URI_HOST=example.com
VMF_GENERATOR_REQUEST_URI_PORT=

# Contact header defaults
# Leave blank to let the generator omit the component or decide later.
VMF_GENERATOR_CONTACT_DISPLAY_NAME=
VMF_GENERATOR_CONTACT_USER=
VMF_GENERATOR_CONTACT_HOST=
VMF_GENERATOR_CONTACT_PORT=
