# ========================================
# volte-mutation-fuzzer Configuration
# ========================================

# ----------------------------------------
# Generator Settings (SIP packet generation)
# ----------------------------------------
VMF_GENERATOR_TARGET_UE_NAME=RealUE
# [LOCAL SOFTPHONE] Run `poe softphone-setup` to see your machine's IP,
# then set VIA_HOST, FROM_HOST, CONTACT_HOST to that IP (e.g. 172.21.38.51).
# Baresip does not bind to 127.0.0.1 — loopback cannot be used as target.
VMF_GENERATOR_VIA_HOST=172.22.0.21
VMF_GENERATOR_VIA_PORT=5060
VMF_GENERATOR_TRANSPORT=UDP
VMF_GENERATOR_USER_AGENT=volte-mutation-fuzzer/0.1.0

# From header defaults
VMF_GENERATOR_FROM_DISPLAY_NAME=Fuzzer
VMF_GENERATOR_FROM_USER=fuzzer
VMF_GENERATOR_FROM_HOST=172.22.0.21
VMF_GENERATOR_FROM_PORT=

# To header defaults
VMF_GENERATOR_TO_DISPLAY_NAME=Target
VMF_GENERATOR_TO_USER=fuzztarget
VMF_GENERATOR_TO_HOST=172.22.0.21
VMF_GENERATOR_TO_PORT=

# Request-URI defaults
VMF_GENERATOR_REQUEST_URI_USER=fuzztarget
VMF_GENERATOR_REQUEST_URI_HOST=172.22.0.21
VMF_GENERATOR_REQUEST_URI_PORT=

# Contact header defaults
VMF_GENERATOR_CONTACT_DISPLAY_NAME=
VMF_GENERATOR_CONTACT_USER=fuzzer
VMF_GENERATOR_CONTACT_HOST=172.22.0.21
VMF_GENERATOR_CONTACT_PORT=

# ----------------------------------------
# Real UE / Infrastructure Settings
# ----------------------------------------
VMF_REAL_UE_SCSCF_CONTAINER=scscf
VMF_REAL_UE_PCSCF_CONTAINER=pcscf
VMF_REAL_UE_PYHSS_URL=http://localhost:8080
VMF_REAL_UE_PCSCF_LOG_TAIL=500
VMF_REAL_UE_UPF_IP=172.22.0.8
VMF_REAL_UE_IMS_SUBNET=10.20.20.0/24

# MT-INVITE Template (3GPP IMS network env)
VMF_IMS_DOMAIN=ims.mnc001.mcc001.3gppnetwork.org
VMF_REAL_UE_PCSCF_IP=172.22.0.21
VMF_SCSCF_IP=172.22.0.20
VMF_SCSCF_PORT=6060
VMF_PCSCF_MT_PORT=6101
VMF_CELL_ID=0010100010019B01
VMF_MO_IMEI=86838903-875492-0
VMF_SDP_OWNER_IP=172.22.0.16
VMF_SDP_AUDIO_PORT=49196

